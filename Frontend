function addToolGrid() {
  const box = document.getElementById("kfChatMessages");
  if (!box) return;

  const grid = document.createElement("div");
  grid.className = "kf-ai-grid";

  tools.forEach((t, i) => {
    const item = document.createElement("div");
    item.className = "kf-ai-card";
    item.style.animationDelay = (i * 0.08) + "s";

    item.innerHTML = `
      <div class="kf-ai-icon">${t.icon}</div>
      <div class="kf-ai-text">${t.text}</div>
    `;

    grid.appendChild(item);
  });

  box.appendChild(grid);
}

function addChatMessage(text, isUser = false) {
  const box = document.getElementById("kfChatMessages");
  if (!box) return;

  const bubble = document.createElement("div");
  bubble.className = "kf-msg " + (isUser ? "kf-msg-user" : "kf-msg-bot");

  if (!isUser) {
    typeText(bubble, text);
  } else {
    bubble.innerText = text;
  }

  box.appendChild(bubble);
  box.scrollTop = box.scrollHeight;
}
function typeText(el, text) {
  let i = 0;
  el.innerText = "";

  const interval = setInterval(() => {
    el.innerText += text[i];   // DO NOT TRIM
    i++;
    if (i >= text.length) clearInterval(interval);
  }, 18);
}





