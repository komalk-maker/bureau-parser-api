     -------------------------------------------- */
  if (customerTypeGlobal === "salaried") {
    selectedEntity = "salaried";
  } else {
    // User selected entity type earlier
    selectedEntity = entityTypeGlobal || "proprietor";
  }

  const entityConfig = getEntityConfig(selectedEntity);
  if (!entityConfig) {
    console.error("Entity config missing for:", selectedEntity);
    return;
  }

  /* --------------------------------------------
     Find product-specific document rules
     -------------------------------------------- */
  const productId = selectedProductName.toLowerCase().replace(/\s+/g, "-");
  const productDocs = getProductSpecificDocs(productId) || [];

  /* --------------------------------------------
     Master required documents list
     -------------------------------------------- */
  selectedDocList = [
    ...(entityConfig.individualKyc || []),
    ...(entityConfig.businessKyc   || []),
    ...(entityConfig.incomeDocs    || []),
    ...productDocs
  ];

  const container = document.getElementById("documentCards");
container.innerHTML = "";

selectedDocList.forEach(doc => {
  const safeId = doc.replace(/\s+/g, '_').replace(/[()]/g, '');

  container.innerHTML += `
    <div class="kf-doc-card">

      <div class="kf-doc-title">${doc}</div>

      <div class="kf-upload-row">
        <button class="kf-upload-btn" onclick="uploadDoc('${doc.replace(/'/g, "\\'")}')">
          Upload
        </button>
      </div>

      <div id="file_${safeId}" class="kf-file-name"></div>

    </div>
  `;
});
}


/* ============================================================
   UPLOAD BUTTON HANDLER
   ============================================================ */
function uploadDoc(docName) {
  const input = document.createElement("input");
  input.type = "file";
  input.accept = "*/*";

  input.onchange = () => {
    const file = input.files[0];
    if (file) {

      // Save in memory
      uploadedDocs[docName] = file;

      // Update UI
      const label = document.getElementById(
        "file_" + docName.replace(/\s+/g, "_")
      );

      if (label) {
        label.textContent = "Uploaded: " + file.name;
      }
    }
  };

  input.click();
}


