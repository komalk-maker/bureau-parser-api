function renderEmiTable(list) {
  if (!list || !list.length) return `<p>No EMI detected in latest month.</p>`;

  let rows = list.map(e => `
    <tr>
      <td>${e.date}</td>
      <td>${e.lender}</td>
      <td>₹${e.amount.toLocaleString()}</td>
    </tr>
  `).join("");

  return `
    <table class="kf-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Lender</th>
          <th>Amount</th>
        </tr>
      </thead>
      <tbody>
        ${rows}
      </tbody>
    </table>
  `;
}

