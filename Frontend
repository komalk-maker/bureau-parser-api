}
// ---------- ROI Master helper (FOR CURRENT STRUCTURE) ----------
function getProductMinRoi(benchKey) {
  const product = ROI_MASTER?.[benchKey];
  if (!product || !product.lenders) return null;

  let best = null;

  Object.entries(product.lenders).forEach(([lender, d]) => {
    const roi = Number(d.minRoi);
    if (!roi || roi <= 0) return;

    if (!best || roi < best.roi) {
      best = { lender, roi };
    }
  });

  return best;
}

function getLendersForProduct(benchKey) {
  const product = ROI_MASTER?.[benchKey];
  if (!product || !product.lenders) return [];

  return Object.entries(product.lenders)
    .map(([name, d]) => ({
      name,
      minRoi: Number(d.minRoi) || 0,
      maxRoi: Number(d.maxRoi) || 0
    }))
    .filter(l => l.minRoi > 0)
    .sort((a, b) => a.minRoi - b.minRoi);
}

function populateLenderSelectForProduct(benchKey, actualRoi) {
  const lenders = getLendersForProduct(benchKey);
  if (!lenders.length) {
    roiLenderBlock.style.display = "none";
    return;
  }

  roiLenderBlock.style.display = "block";
  roiLenderSelect.innerHTML =
    '<option value="">Select lender from ROI master</option>';

  lenders.forEach((l, i) => {
    const opt = document.createElement("option");
    opt.value = i;
    opt.textContent = `${l.name} – from ${l.minRoi.toFixed(2)}%`;
    roiLenderSelect.appendChild(opt);
  });

  roiLenderSelect.onchange = () => {
    const i = +roiLenderSelect.value;
    if (isNaN(i)) return;

    const l = lenders[i];
    const diff = actualRoi - l.minRoi;

    roiLenderResult.innerHTML = `
      <div>
