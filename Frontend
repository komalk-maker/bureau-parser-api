function initCreditCardAccordions() {
  document.querySelectorAll(".kf-accordion").forEach(acc => {
    const header = acc.querySelector(".kf-acc-header");
    const body = acc.querySelector(".kf-acc-body");
    const chev = acc.querySelector(".kf-acc-chevron");

    if (!header || !body) return;

    body.style.display = "none";

    header.addEventListener("click", () => {
      const isOpen = body.style.display === "block";
      body.style.display = isOpen ? "none" : "block";
      chev.style.transform = isOpen ? "rotate(0deg)" : "rotate(180deg)";
    });
  });
}
