  function buildScoreSimulatorFactorsText(loansWithOverdue, cardUtilRatio, enqSummary, mixInfo) {
    const lines = [];
    if (loansWithOverdue.length > 0) {
      lines.push("• Overdues reported on active loans");
    } else {
      lines.push("• No active overdue – keep EMIs 100% on time");
    }

    if (cardUtilRatio == null) {
      lines.push("• No credit card limit reported");
    } else if (cardUtilRatio > 0.8) {
      lines.push("• Very high overall credit card utilisation (>80%)");
    } else if (cardUtilRatio > 0.5) {
      lines.push("• Moderate card utilisation (50–80%) – can be improved");
    } else {
      lines.push("• Healthy card utilisation (<50%)");
    }

    const enq6 = enqSummary["6"];
    if (enq6 && enq6.total > 0) {
      if (enq6.unsecuredCount >= 5) {
        lines.push("• Many recent unsecured enquiries in last 6 months");
      } else if (enq6.unsecuredCount >= 2) {
        lines.push("• Few unsecured enquiries in last 6 months");
      } else {
        lines.push("• Mostly secured / low enquiries in last 6 months");
      }
    } else {
      lines.push("• No recent enquiries in last 6 months");
    }

    if (mixInfo) {
      const { securedPct, unsecuredPct } = mixInfo;
      if (unsecuredPct > 60) {
        lines.push("• High share of unsecured loans vs secured");
      } else if (securedPct >= 50) {
        lines.push("• Reasonable share of secured loans");
      }
    }

    return lines.join("<br>");
  }

