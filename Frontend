  function scoreCardForUser(card, prefs) {
  const level = segmentLevel(card.segment);
  const minIncome = estimatedMinIncome(level);
  const tags = deriveTags(card);

  let score = 0;
  const reasons = [];

  // -------------------------
  // 1. Income Suitability
  // -------------------------
  if (prefs.income && prefs.income < minIncome) {
    score -= 40;
    reasons.push("Your income is lower than typical for this card segment.");
  } else if (prefs.income && prefs.income >= minIncome) {
    score += 20;
    reasons.push("Your income matches this card’s eligibility range.");
  }

  // -------------------------
  // 2. Primary Goal
  // -------------------------
  if (prefs.goal === "cashback" && tags.includes("cashback")) {
    score += 30;
    reasons.push("This card aligns with your cashback goal.");
  }
  if (prefs.goal === "shopping" && tags.includes("online")) {
    score += 30;
    reasons.push("This card is good for online shopping.");
  }
  if (prefs.goal === "travel" && tags.includes("travel")) {
    score += 30;
    reasons.push("This card enhances your travel benefits.");
  }
  if (prefs.goal === "fuel" && tags.includes("fuel")) {
    score += 30;
    reasons.push("This card offers fuel-related benefits.");
  }
  if (prefs.goal === "dining" && tags.includes("dining")) {
    score += 30;
    reasons.push("This card supports dining spends.");
  }

  // -------------------------
  // 3. Fee Preference
  // -------------------------
  if (prefs.feePref === "free") {
    if (card.joining_fee_rs === 0 && card.renewal_fee_rs === 0) {
      score += 25;
      reasons.push("This card is lifetime-free, which matches your preference.");
    } else if (card.joining_fee_rs <= 500) {
      score += 10;
    } else {
      score -= 10;
    }
  }

  if (prefs.feePref === "premium") {
    if (level >= 3) {
      score += 20;
      reasons.push("You prefer premium cards and this one fits.");
    }
  }

  // -------------------------
  // 4. Platform Match
  // -------------------------
  const pm = platformMatchScore(card, prefs.platform);
  score += pm;
  if (pm > 0) reasons.push("Matches your preferred shopping platform.");

  // -------------------------
  // 5. Spend Tags Match
  // -------------------------
  const spend = prefs.spendTags || [];
  if (spend.includes("online") && tags.includes("online")) score += 15;
  if (spend.includes("fuel") && tags.includes("fuel")) score += 15;
  if (spend.includes("dining") && tags.includes("dining")) score += 15;
  if (spend.includes("travel") && tags.includes("travel")) score += 15;

  // -------------------------
  // 6. International Travel
  // -------------------------
  if (prefs.intlTravel === "frequent" && tags.includes("travel")) {
    score += 15;
    reasons.push("Better suited for international travel.");
  }

  // -------------------------
  // NEW LOGIC SECTION — Extra Charges Weightage
  // -------------------------

  // 7. Foreign Transaction Fee
  if (card.foreign_txn_fee_percent > 0) {
    if (card.foreign_txn_fee_percent <= 2) score += 10;
    else if (card.foreign_txn_fee_percent <= 3.5) score += 5;
    else score -= 5;
  }

  // 8. APR Score
  if (card.finance_charge_apr_percent > 0) {
    if (card.finance_charge_apr_percent <= 24) score += 10;
    else if (card.finance_charge_apr_percent <= 36) score += 5;
    else score -= 10;
  }

  // 9. Cash Advance Fee Notes
  if (card.cash_advance_fee_notes && card.cash_advance_fee_notes !== "") {
    score -= 5; // cash advance is always negative behaviour
  }

  // 10. Overlimit Fee
  if (card.overlimit_fee_notes && card.overlimit_fee_notes !== "") {
    score -= 3;
  }

  // 11. Cash Limit Notes
  if (card.cash_limit_notes && card.cash_limit_notes !== "") {
    score += 2;
  }

  // Return final bundle
  return { score, reasons, level, minIncome, tags };
}


