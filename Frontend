function addChatMessage(text, isUser = false) {
  const box = document.getElementById("kfChatMessages");
  if (!box) return;

  const bubble = document.createElement("div");
  bubble.className = "kf-msg " + (isUser ? "kf-msg-user" : "kf-msg-bot");
  bubble.innerText = text;

  box.appendChild(bubble);
  box.scrollTop = box.scrollHeight;
}

/* =========================================================
   🚀 SEND CHAT MESSAGE (API)
   ========================================================= */
async function sendChatMessage() {
  const input = document.getElementById("kfChatInput");
  if (!input) return;

  const text = input.value.trim();
  if (!text) return;

  addChatMessage(text, true);
  input.value = "";

  addChatMessage("Typing…");

  try {
    const res = await fetch("https://bureau-parser-api.onrender.com/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        question: text,
        analysis: window.kfDashboardData,
        extras: window.kfExtraInsights,
        logic: window.kfLogicDump
      })
    });

    const data = await res.json();

    const box = document.getElementById("kfChatMessages");
    if (box && box.lastElementChild) {
      box.removeChild(box.lastElementChild);
    }

    if (data.success) {
      addChatMessage(data.answer);
    } else {
      addChatMessage("Error: " + (data.message || "Something went wrong"));
    }

  } catch (err) {
    const box = document.getElementById("kfChatMessages");
    if (box && box.lastElementChild) {
      box.removeChild(box.lastElementChild);
    }
    addChatMessage("Network error. Please try again.");
    console.error(err);
  }
}

