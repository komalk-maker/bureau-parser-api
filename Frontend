function renderCreditCardUtilisation(loans) {

  let totalSanction = 0;
  let totalOutstanding = 0;
  const ccLoans = [];

  // -----------------------------
  // Aggregate credit card data
  // -----------------------------
  loans.forEach(l => {
    if (!isCreditCardLoan(l)) return;

    const sanction = getSanctionAmount(l) || 0;
    const outstanding = getCurrentBalance(l) || 0;

    totalSanction += sanction;
    totalOutstanding += outstanding;

    ccLoans.push({ l, sanction, outstanding });
  });

  const percentEl   = document.getElementById("ccUtilPercent");
  const badgeEl     = document.getElementById("ccUtilBadge");
  const barEl       = document.getElementById("ccUtilBar");

  const totalLimitEl     = document.getElementById("ccTotalLimit");
  const usedLimitEl      = document.getElementById("ccUsedLimit");
  const availableLimitEl = document.getElementById("ccAvailableLimit");

  // -----------------------------
  // No credit cards case
  // -----------------------------
  if (totalSanction === 0) {
    percentEl.textContent = "--%";
    badgeEl.textContent = "--";
    barEl.style.width = "0%";

    totalLimitEl.textContent = "₹--";
    usedLimitEl.textContent = "₹--";
    availableLimitEl.textContent = "₹--";

    document.getElementById("ccCardsContainer").innerHTML = "";
    return;
  }

  // -----------------------------
  // Calculations
  // -----------------------------
  const availableTotal = Math.max(totalSanction - totalOutstanding, 0);
  const utilPct = (totalOutstanding / totalSanction) * 100;
  const utilPctRounded = utilPct.toFixed(1);

  // -----------------------------
  // Update summary numbers
  // -----------------------------
  totalLimitEl.textContent =
    "₹" + totalSanction.toLocaleString();

  usedLimitEl.textContent =
    "₹" + totalOutstanding.toLocaleString();

  availableLimitEl.textContent =
    "₹" + availableTotal.toLocaleString();

  // -----------------------------
  // Update utilisation %
  // -----------------------------
  percentEl.textContent = utilPctRounded + "%";
  barEl.style.width = Math.min(utilPct, 100) + "%";

  // -----------------------------
  // Badge logic
  // -----------------------------
  let badgeText = "";
  let badgeClass = "";

  if (utilPct <= 50) {
    badgeText = "Healthy";
    badgeClass = "cc-good";
  }
  else if (utilPct <= 75) {
    badgeText = "Par";
    badgeClass = "cc-par";
  }
  else if (utilPct <= 100) {
    badgeText = "Needs Reduction";
    badgeClass = "cc-watch";
  }
  else {
    badgeText = "Overutilised";
    badgeClass = "cc-bad";
  }

  badgeEl.textContent = badgeText;
  badgeEl.className = "kf-util-badge " + badgeClass;

  // -----------------------------
  // Store for reference (optional)
  // -----------------------------
  document.getElementById("ccUtilSummary")._ccLoans = ccLoans;

  // -----------------------------
  // Render inline card list
  // -----------------------------
  renderCreditCardsInline(ccLoans);
}



