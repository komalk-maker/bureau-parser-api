  // ---------- Shared helpers for 11th card (eligibility) ----------

  function computeEligibilityForLoan(params) {
    // params: { productId, amount, tenure, customerType }
    const { productId, amount, tenure, customerType } = params;
    const emi = calculateNewLoanEmi(amount, tenure, productId);
    if (!emi) return null;

    const existingMonthly = getExistingTotalMonthlyEmi();
    const totalMonthly = existingMonthly + emi;
    const totalYearly = totalMonthly * 12;

    // FOIR/DSCR same as profit card (defaults)
    let foirPerc = 50;
    let dscrTarget = 1.2;

    const salariedMonthlyIncome = totalMonthly / (foirPerc / 100);
    const salariedYearlyIncome = salariedMonthlyIncome * 12;

    const businessRequiredYearly = totalYearly * dscrTarget;
    const businessRequiredMonthly = businessRequiredYearly / 12;

    const requiredAvgBankBalance = totalMonthly * 2; // 2:1 rule, same as alt card

    return {
      emi,
      existingMonthly,
      totalMonthly,
      totalYearly,
      foirPerc,
      dscrTarget,
      salariedMonthlyIncome,
      salariedYearlyIncome,
      businessRequiredMonthly,
      businessRequiredYearly,
      requiredAvgBankBalance
    };
  }

  function computeGstEligibilityForSelfEmployed(params) {
    // params: { industry, profile, turnover, productId, amount, tenure }
    const { industry, profile, turnover, productId, amount, tenure } = params;

    const industryRow = INDUSTRY_MARGINS[industry];
    if (!industryRow) return { error: "Industry margin not found in master." };

    const marginPerc = industryRow[profile];
    if (marginPerc == null) {
      return { error: "Margin not defined for this industry & profile combination." };
    }

    const emi = calculateNewLoanEmi(amount, tenure, productId);
    if (!emi) return { error: "Unable to calculate EMI for this loan." };

    const existingMonthly = getExistingTotalMonthlyEmi();
    const totalMonthly = existingMonthly + emi;
    const yearlyObligation = totalMonthly * 12;

    // Same formula as alt GST card: Income = Turnover × Margin% × 70%
    const income = turnover * (marginPerc / 100) * 0.7;
    const eligible = income >= yearlyObligation;

    return {
      marginPerc,
      income,
      yearlyObligation,
      eligible
    };
  }

  // ---------- Bureau-based rejection reasons for 11th card ----------

  function buildBureauRejectionReasons() {
    if (!lastResult) return [];
    const reasons = [];
    const fmt = x => "₹" + formatINR(Math.round(x));

    const loans = allLoans || [];
    const active = activeLoans || [];
    const enquiries = Array.isArray(lastResult.enquiries) ? lastResult.enquiries : [];

    const scoreNum =
      parseInt(scoreValue?.textContent || lastResult.score || "0", 10) || 0;

    const loansWithOverdue = loans.filter(
      l => (l.details?.amountOverdue || 0) > 0
    );

    let worstDpd = 0;
    loans.forEach(l => {
      const d = l.details || {};
      const maxDpd = getMaxDpdFromHistory(d.dpdHistory);
      if (maxDpd > worstDpd) worstDpd = maxDpd;
    });

    // Card utilisation
    const cards = active.filter(isCreditCardLoan);
    let totalCardLimit = 0;
    let totalCardBal = 0;
    cards.forEach(l => {
      const d = l.details || {};
      const limit =
        d.creditLimit != null
          ? Number(d.creditLimit)
          : d.highCredit != null
          ? Number(d.highCredit)
          : 0;
      const bal = d.currentBalance != null ? Number(d.currentBalance) : 0;
      totalCardLimit += isNaN(limit) ? 0 : limit;
      totalCardBal += isNaN(bal) ? 0 : bal;
    });
    const cardUtil = totalCardLimit > 0 ? totalCardBal / totalCardLimit : null;

    // Enquiry summary (uses same helper as score simulator)
    let enqSummary = null;
    if (typeof summariseEnquiriesForSimulator === "function") {
      enqSummary = summariseEnquiriesForSimulator(enquiries);
    }

    // Credit mix
    let mixInfo = null;
    if (typeof getCreditMixInfo === "function") {
      mixInfo = getCreditMixInfo(active);
    }

    // Helper: build little tables
    const buildOverdueTableHtml = () => {
      if (!loansWithOverdue.length) return "";
      let rows = "";
      loansWithOverdue.forEach(l => {
        const d = l.details || {};
        const bank = d.lender || getBankName(l.line || "");
        const type = d.accountType || l.type || "Account";
        const overdue = d.amountOverdue || 0;
        const dpd = getMaxDpdFromHistory(d.dpdHistory);
        rows += `
          <tr>
            <td>${bank}</td>
            <td>${type}</td>
            <td>₹${formatINR(overdue)}</td>
            <td>${dpd || 0} days</td>
          </tr>
        `;
      });
      return `
        <div style="margin-top:4px;overflow-x:auto;">
          <table class="kf-payhist-table">
            <thead>
              <tr>
                <th>Lender</th>
                <th>Facility</th>
                <th>Overdue</th>
                <th>Worst DPD</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
      `;
    };

    const buildCardUtilTableHtml = () => {
      if (!cards.length) return "";
      let rows = "";
      cards.forEach(l => {
        const d = l.details || {};
        const bank = d.lender || getBankName(l.line || "");
        const limit =
          d.creditLimit != null
            ? Number(d.creditLimit)
            : d.highCredit != null
            ? Number(d.highCredit)
            : 0;
        const bal = d.currentBalance != null ? Number(d.currentBalance) : 0;
        const util = limit > 0 ? (bal / limit) * 100 : 0;
        rows += `
          <tr>
            <td>${bank}</td>
            <td>₹${formatINR(limit)}</td>
            <td>₹${formatINR(bal)}</td>
            <td>${util.toFixed(0)}%</td>
          </tr>
        `;
      });
      return `
        <div style="margin-top:4px;overflow-x:auto;">
          <table class="kf-payhist-table">
            <thead>
              <tr>
                <th>Lender</th>
                <th>Limit</th>
                <th>Balance</th>
                <th>Utilisation</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
      `;
    };

    // 1. No credit history (NH/NA)
    if (!scoreNum && loans.length === 0) {
      reasons.push({
        id: "noHistory",
        title: "No credit history (NH/NA)",
        valueText: "No active / closed loans or credit cards are visible in this bureau report.",
        fixText:
          "Start with low-risk products: a secured credit card / add-on card / small consumer durable loan. " +
          "Repay on time for 6–9 months to build a score before applying again.",
        detailHtml: ""
      });
      return reasons; // if no history, other bureau reasons don’t apply
    }

    // 2. Low bureau score
    if (scoreNum > 0 && scoreNum < 700) {
      reasons.push({
        id: "lowScore",
        title: "Low bureau score",
        valueText: `Score in this report: <b>${scoreNum}</b> (many lenders prefer ≥ 720).`,
        fixText:
          "Reduce credit card utilisation below 30%, clear overdues, avoid new enquiries, " +
          "and maintain 6–12 months of on-time EMI and credit card payments before reapplying.",
        detailHtml: ""
      });
    }

    // 3. Current overdues
    if (loansWithOverdue.length) {
      reasons.push({
        id: "overdues",
        title: "Current overdues (DPD > 0 on active accounts)",
        valueText: `We found <b>${loansWithOverdue.length}</b> facility(ies) with overdue reported.`,
        fixText:
          "Immediately clear overdue EMIs / credit card dues, obtain updated statements, and maintain 3–6 months of 0 DPD before reapplying.",
        detailHtml: buildOverdueTableHtml()
      });
    }

    // 4. DPD severity (30+ / 60+ / 90+)
    if (worstDpd >= 30) {
      let dpdTitle = "";
      let plan = "";
      if (worstDpd >= 90) {
        dpdTitle = "90+ DPD observed in your payment history";
        plan =
          "Close / regularise all such accounts, obtain NOC if closed, and maintain perfect behaviour for 12–18 months.";
      } else if (worstDpd >= 60) {
        dpdTitle = "60+ DPD observed in your payment history";
        plan =
          "Prioritise clearing high-delay accounts, avoid restructuring unless necessary, and rebuild track for 6–12 months.";
      } else {
        dpdTitle = "30+ DPD observed in your payment history";
        plan =
          "Clear pending EMIs, set up auto-debit/ECS, and ensure 90 days of on-time payments before reapplying.";
      }
      reasons.push({
        id: "dpdSeverity",
        title: dpdTitle,
        valueText: `Worst delay seen in this report: <b>${worstDpd} days</b>.`,
        fixText: plan,
        detailHtml: ""
      });
    }

    // 5. Special statuses: Settled / Written-off / Restructured / Suit filed
    const flaggedLoans = { settled: [], writtenOff: [], postWoSettled: [], suit: [], restructured: [] };
    loans.forEach(l => {
      const d = l.details || {};
      const status = (d.accountStatus || l.status || "").toLowerCase();
      if (!status) return;
      if (status.includes("settled") && !status.includes("post write-off")) {
        flaggedLoans.settled.push(l);
      }
      if (status.includes("written") || status.includes("write-off") || status.includes("write off")) {
        flaggedLoans.writtenOff.push(l);
      }
      if (status.includes("post write-off") || status.includes("post write off")) {
        flaggedLoans.postWoSettled.push(l);
      }
      if (status.includes("suit filed") || status.includes("wilful") || status.includes("willful")) {
        flaggedLoans.suit.push(l);
      }
      if (status.includes("restructured")) {
        flaggedLoans.restructured.push(l);
      }
    });

    const buildSimpleLoanList = arr => {
      if (!arr.length) return "";
      let rows = "";
      arr.forEach(l => {
        const d = l.details || {};
        const bank = d.lender || getBankName(l.line || "");
        const type = d.accountType || l.type || "Account";
        rows += `<li>${bank} – ${type}</li>`;
      });
      return `
        <ul style="margin:4px 0 0 16px;font-size:12px;color:#374151;">
          ${rows}
        </ul>
      `;
    };

    if (flaggedLoans.settled.length) {
      reasons.push({
        id: "settled",
        title: "Settled account reported in bureau",
        valueText: `We see at least <b>${flaggedLoans.settled.length}</b> settled account(s).`,
        fixText:
          "Where possible, convert settlement into full payment or close balance amount, collect NOC, " +
          "and build a clean track record for 12+ months.",
        detailHtml: buildSimpleLoanList(flaggedLoans.settled)
      });
    }
    if (flaggedLoans.writtenOff.length) {
      reasons.push({
        id: "writtenOff",
        title: "Written-off account in bureau",
        valueText: `We see at least <b>${flaggedLoans.writtenOff.length}</b> written-off account(s).`,
        fixText:
          "Negotiate and clear dues with lender, obtain closure letter, and then slowly rebuild credit with small, well-managed products.",
        detailHtml: buildSimpleLoanList(flaggedLoans.writtenOff)
      });
    }
    if (flaggedLoans.postWoSettled.length) {
      reasons.push({
        id: "postWoSettled",
        title: "Post write-off – settled account",
        valueText: `We see <b>${flaggedLoans.postWoSettled.length}</b> post write-off settled account(s).`,
        fixText:
          "Keep all current facilities 100% regular, avoid fresh unsecured borrowing, and allow 12–24 months for score normalisation.",
        detailHtml: buildSimpleLoanList(flaggedLoans.postWoSettled)
      });
    }
    if (flaggedLoans.suit.length) {
      reasons.push({
        id: "suitFiled",
        title: "Suit filed / wilful default reported",
        valueText: "Legal / high-risk remark present in your bureau report.",
        fixText:
          "Resolve the legal case with lender wherever feasible, clear dues, and get the updated status reflected in your bureau. " +
          "Until then, most lenders will not approve fresh credit.",
        detailHtml: buildSimpleLoanList(flaggedLoans.suit)
      });
    }
    if (flaggedLoans.restructured.length) {
      reasons.push({
        id: "restructured",
        title: "Account marked as restructured",
        valueText: `We see <b>${flaggedLoans.restructured.length}</b> restructured facility(ies).`,
        fixText:
          "Ensure zero DPD after restructuring and build a clean track for 12–18 months. Some lenders will remain conservative even then.",
        detailHtml: buildSimpleLoanList(flaggedLoans.restructured)
      });
    }

    // 6. Too many enquiries / unsecured spike
    if (enqSummary) {
      const s1 = enqSummary["1"];
      const s3 = enqSummary["3"];
      if (s1 && s1.total > 10) {
        reasons.push({
          id: "enq30",
          title: "Too many enquiries in last 30 days",
          valueText: `Approx <b>${s1.total}</b> enquiries in last 30 days (threshold ~ 10).`,
          fixText:
            "Stop all new loan / credit card applications, wait at least 60 days, and then apply only for one suitable product via a trusted channel.",
          detailHtml: ""
        });
      }
      if (s3 && s3.total > 15) {
        reasons.push({
          id: "enq90",
          title: "Too many enquiries in last 90 days",
          valueText: `Approx <b>${s3.total}</b> enquiries in last 90 days (threshold ~ 15).`,
          fixText:
            "Pause applications for 3 months, improve bank statement profile and utilisation, then apply selectively for 1–2 products max.",
          detailHtml: ""
        });
      }
      if (s1 && s1.unsecured > 10) {
        reasons.push({
          id: "unsecuredSpike",
          title: "Unsecured loan enquiry spike (last 30 days)",
          valueText: `Approx <b>${s1.unsecured}</b> unsecured loan / card enquiries in last 30 days.`,
          fixText:
            "Avoid multiple personal loan and credit card applications. Explore secured / guaranteed options instead and wait 3–6 months.",
          detailHtml: ""
        });
      }
    }

    // 7. High credit card utilisation
    if (cardUtil != null && cardUtil >= 0.75) {
      const utilPerc = (cardUtil * 100).toFixed(0);
      let title = "High credit card utilisation (> 75%)";
      if (cardUtil >= 0.9) title = "Maxed-out credit card utilisation (> 90%)";

      const fix =
        cardUtil >= 0.9
          ? "Make lump-sum payments to significantly reduce outstanding, avoid using full limit again, and convert to lower-cost EMI only if needed."
          : "Pay down card balances to bring utilisation below 30–40% of total limit; avoid cash withdrawals and EMIs on cards.";

      reasons.push({
        id: "cardUtil",
        title,
        valueText: `Overall utilisation: <b>${utilPerc}%</b> of total credit limit.`,
        fixText: fix,
        detailHtml: buildCardUtilTableHtml()
      });
    }

    // 8. High proportion of unsecured vs secured
    if (mixInfo && mixInfo.total >= 2 && mixInfo.unsecuredPct >= 70) {
      reasons.push({
        id: "mix",
        title: "High proportion of unsecured credit",
        valueText: `Approx <b>${mixInfo.unsecuredPct.toFixed(
          0
        )}%</b> of your exposure is unsecured.`,
        fixText:
          "Gradually reduce unsecured exposure and, where relevant, build secured credit (home / auto / secured card) with disciplined repayment.",
        detailHtml: ""
      });
    }

    // 9. Multiple new loans in short period (simple 90-day check)
    const ninetyDaysAgo = (() => {
      const d = new Date();
      d.setDate(d.getDate() - 90);
      return d;
    })();
    let newLoans90 = 0;
    active.forEach(l => {
      const d = parseDateSafe(l.details?.dateOpened);
      if (d && d >= ninetyDaysAgo) newLoans90++;
    });
    if (newLoans90 > 4) {
      reasons.push({
        id: "newLoans",
        title: "Multiple new loans opened in short period",
        valueText: `At least <b>${newLoans90}</b> loan(s) opened in roughly last 90 days.`,
        fixText:
          "Pause new borrowing, demonstrate repayment capacity over 6–12 months, and avoid overlapping new loans.",
        detailHtml: ""
      });
    }

    return reasons;
  }


