function classifyLoanForRoiBenchmark(l) {
  const meta = getProductMeta(l);
  const label = (meta?.label || l.details?.accountType || l.type || "").toLowerCase();
  const id = (meta?.id || "").toUpperCase();
  const line = (l.line || "").toLowerCase();

  if (label.includes("personal")) return "PERSONAL_LOAN";
  if (label.includes("business")) return "BUSINESS_LOAN";
  if (label.includes("home") || label.includes("housing")) return "HOUSING_LOAN";
  if (label.includes("lap") || label.includes("property")) return "LAP";
  if (label.includes("gold")) return "GOLD_LOAN";
  if (label.includes("2 wheeler") || label.includes("two wheeler")) return "AUTO_2W";
  if (label.includes("4 wheeler") || label.includes("car")) return "AUTO_4W";
  if (label.includes("commercial") || label.includes("cv")) return "COMMERCIAL_VEHICLE";

  return null;
}

function buildRoiLoanOptionLabel(l) {
  const d = l.details || {};
