function getLoanRoi(l) {
  // ===================================================
  // Helpers
  // ===================================================
  function parseRoiRaw(raw) {
    if (raw == null) return null;
    const s = String(raw).trim();
    if (!s) return null;
    const m = s.match(/-?\d+(\.\d+)?/);
    if (!m) return null;
    const n = parseFloat(m[0]);
    return isNaN(n) ? null : n;
  }

  // ===================================================
  //1️⃣ Bureau ROI (highest priority)
  // ===================================================
  const d = l.details || {};
  const bureauCandidates = [
    d.interestRate,
    d.roi,
    d.rate,
    d.rateOfInterest,
    d.interest_rate,
    d.rate_of_interest,
    d.interestPercent,
    d.interest_percent,
    d.annualInterestRate,
    d.annual_rate
  ];

  for (const raw of bureauCandidates) {
    const val = parseRoiRaw(raw);
    if (val != null) {
      console.log("✅ ROI from bureau", val);
      return val;
    }
  }

  const meta = getProductMeta(l) || {};

  // ===================================================
  // 2️⃣ SIMPLE-INTEREST PRODUCTS → STOP HERE
  // ===================================================
  if (isSimpleInterestProduct?.(l, meta)) {
    console.log("ℹ️ Simple-interest product → ROI from product master", meta?.roi);
    return meta?.roi ?? null;
  }

  // ===================================================
  // 3️⃣ Reducing-balance ROI derivation
  // ===================================================
  const openDate =
    d.dateOpened ||
    d.opened ||
    l.opened ||
    null;

  const monthsPaid =
    openDate && Number.isFinite(countPaidEmis(openDate))
      ? Math.round(countPaidEmis(openDate))
      : null;

  if (!monthsPaid || monthsPaid <= 0) {
    console.warn("🚫 ROI derivation skipped (EMI count unavailable)");
    return meta?.roi ?? null;
  }

  const P = getSanctionAmount(l);
  const currentOS = getCurrentBalance(l);

  if (!(P > 0 && currentOS > 0)) {
    return meta?.roi ?? null;
  }

  let TENURE_BUCKETS;
  if (["HOME", "LAP", "MORTGAGE"].includes(meta.id)) {
    TENURE_BUCKETS = [60, 84, 120, 180, 240, 300, 360];
  } else {
    TENURE_BUCKETS = [6, 9, 12, 18, 24, 30, 36, 48, 60];
  }

  if (meta?.probableTenureRange && meta?.probableRoiRange) {
    const [minTenure, maxTenure] = meta.probableTenureRange;
    const [minRoi, maxRoi] = meta.probableRoiRange;

    let best = null;

    for (const T of TENURE_BUCKETS) {
      if (T < minTenure || T > maxTenure) continue;
      if (monthsPaid >= T) continue;

      for (let roi = minRoi; roi <= maxRoi; roi += 0.25) {
        const r = roi / 12 / 100;
        const emi =
          r === 0
            ? P / T
            : (P * r * Math.pow(1 + r, T)) /
              (Math.pow(1 + r, T) - 1);

        const os =
          P * Math.pow(1 + r, monthsPaid) -
          emi * ((Math.pow(1 + r, monthsPaid) - 1) / r);

        const error = Math.abs(os - currentOS);

        if (!best || error < best.error) {
          best = { roi, tenure: T, error };
        }
      }
    }

    if (best && best.error <= P * 0.01) {
      const loanKey =
        d.accountNumber ||
        `${meta.id}-${openDate}`;

      DERIVED_LOAN_TENURE.set(loanKey, best.tenure);

      console.log("✅ ROI & TENURE DERIVED", best);
      return best.roi;
    }
  }

  console.warn("↩ ROI fallback to product master", meta?.roi);
  return meta?.roi ?? null;
}




  function parseDateSafe(str) {
