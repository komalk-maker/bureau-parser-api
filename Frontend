  function classifyLoanSecuredFlag(l) {
    // Returns "secured" or "unsecured" for credit mix
    const meta = getProductMeta(l);
    const label = (meta?.label || "").toLowerCase();
    const t = (l.type || "").toLowerCase();
    const at = (l.details?.accountType || "").toLowerCase();
    const line = (l.line || "").toLowerCase();
    const text = " " + label + " " + t + " " + at + " " + line + " ";

    // Clear unsecured: PL / BL / credit card / consumer / microfinance
    if (isCreditCardLoan(l)) return "unsecured";
    if (isPersonalLoan(l)) return "unsecured";
    if (text.includes("consumer") || text.includes("microfinance")) return "unsecured";
    if (text.includes("business loan")) return "unsecured";

    // Clearly secured: home / lap / mortgage / auto / vehicle / tractor / farm / property / gold / OD with security
    if (
      text.includes("home loan") ||
      text.includes("housing loan") ||
      text.includes("mortgage") ||
      text.includes("lap") ||
      text.includes("loan against property") ||
      text.includes("gold loan") ||
      text.includes("vehicle") ||
      text.includes("auto loan") ||
      text.includes("car loan") ||
      text.includes("tractor") ||
      text.includes("farm") ||
      text.includes("secured od") ||
      text.includes("loan against shares") ||
      text.includes("loan against mf") ||
      text.includes("residential property") ||
      text.includes("commercial property")
    ) {
      return "secured";
    }

    // Default: treat as unsecured (conservative from score perspective)
    return "unsecured";
  }

  function classifyEnquirySecuredFlag(e) {
    const type = (e.enquiryType || "").toLowerCase();
    const text = " " + type + " ";

    const unsecuredKw = [
      "personal loan",
      "business loan",
      "credit card",
      "consumer",
      "microfinance",
      "pl ",
      "bl "
    ];
    const securedKw = [
      "home loan",
      "housing",
      "mortgage",
      "lap",
      "loan against property",
      "gold loan",
      "auto loan",
      "car loan",
      "tractor",
      "farm",
      "vehicle"
    ];

    for (const kw of securedKw) if (text.includes(kw)) return true;
    for (const kw of unsecuredKw) if (text.includes(kw)) return false;

    // Unknown → treat as unsecured (safer for user)
    return false;
  }

  function summariseEnquiriesForSimulator(enquiries) {
    const now = new Date();
    const buckets = {
      "1": { label: "Last 1 month", items: [] },
      "3": { label: "Last 3 months", items: [] },
      "6": { label: "Last 6 months", items: [] }
    };

    enquiries.forEach(e => {
      const d = parseDateSafe(e.date);
      if (!d) return;
      const diffDays = (now - d) / (1000 * 60 * 60 * 24);
      const isSecured = classifyEnquirySecuredFlag(e);

      const record = {
        institution: e.institution || "Institution",
        type: e.enquiryType || "Type",
        date: e.date || "",
        isSecured
      };

      if (diffDays <= 30) buckets["1"].items.push(record);
      if (diffDays <= 90) buckets["3"].items.push(record);
      if (diffDays <= 180) buckets["6"].items.push(record);
    });

    // transform to summary
    const out = {};
    Object.keys(buckets).forEach(key => {
      const b = buckets[key];
      const secured = b.items.filter(x => x.isSecured);
      const unsecured = b.items.filter(x => !x.isSecured);
      out[key] = {
        label: b.label,
        total: b.items.length,
        securedCount: secured.length,
        unsecuredCount: unsecured.length,
        all: b.items,
        secured,
        unsecured
      };
    });
    return out;
  }

