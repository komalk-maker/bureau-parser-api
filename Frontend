  const emiDay =
    Number(d.emiDueDay || d.dueDay || d.emiDate || 5) || 5;

  // 3. Today's date
  const today = new Date();

  // --- RULE OF FIRST EMI BASED ON SANCTION DATE ---
  // If sanctioned BEFORE OR ON 20 → next month
  // If sanctioned AFTER 20 → month after next

  let firstEmiMonthOffset = sanctionDate.getDate() <= 20 ? 1 : 2;

  // First EMI date:
  const firstEmiDate = new Date(
    sanctionDate.getFullYear(),
    sanctionDate.getMonth() + firstEmiMonthOffset,
    emiDay
  );

  // If today is before the first EMI → return first EMI
  if (today < firstEmiDate) return firstEmiDate;

  // --- IF ALREADY STARTED, FIND NEXT EMI CYCLE ---
  // EMI is monthly – stick to scheduled EMI date each month.
  let nextEmi = new Date(
    today.getFullYear(),
    today.getMonth(),
    emiDay
  );

  // If this month's EMI is already passed → move to next month
  if (nextEmi <= today) {
    nextEmi = new Date(
      today.getFullYear(),
      today.getMonth() + 1,
      emiDay
    );
  }

  return nextEmi;
}


// estimate total INTEREST remaining from now on (not outstanding principal)
function estimateInterestRemaining(l) {
  const meta = getProductMeta(l) || {};

  // ---- Outstanding based on NEXT/CURRENT logic ----
  const outstanding = getCurrentBalanceFromSchedule(l) || 0;
  if (!outstanding || outstanding <= 0) return 0;

  // ---- ROI ----
  const roi = getLoanRoi(l);
  if (!roi || roi <= 0) return 0;
  const r = roi / 1200;

  // ---- Simple interest products stay same ----
  if (isSimpleInterestProduct(l, meta)) {
    const remainingMonths = getLoanRemainingTenureMonths(l) || 0;
    return Math.round(outstanding * r * remainingMonths);
  }

  // ---- EMI-based loans: EXACT amortization remaining interest ----

  // Build full schedule (opening, interest, principal, closing)
  const schedule = buildEmiScheduleData(l);
  if (!schedule.length) return 0;

  // Find which row matches the CURRENT outstanding
  // Because getCurrentBalanceFromSchedule() already returns a schedule closing value
  // we just find the FIRST row where closing <= outstanding
  let startIndex = schedule.findIndex(row =>
    Math.round(row.closing) === Math.round(outstanding)
  );

  // Fallback if no exact match: choose nearest lower balance
  if (startIndex === -1) {
    startIndex = schedule.findIndex(row => row.closing <= outstanding);
    if (startIndex === -1) startIndex = 0;
  }

  // We must sum interest from the NEXT row
  const nextIndex = startIndex + 1;

  let totalInterest = 0;
  for (let i = nextIndex; i < schedule.length; i++) {
    totalInterest += schedule[i].interest;
  }

  return Math.round(totalInterest);
}

  
