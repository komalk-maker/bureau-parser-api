function estimateMonthlyEmi(l) {
  // preserve existing helpers usage
  const meta = getProductMeta(l) || {};
  const principal = getSanctionAmount(l) || getCurrentBalance(l) || 0;
  if (!principal || principal <= 0) return 0;

  // --- get ROI (prefer bureau, else product master) ---
  let roi = l?.details?.rateOfInterest ?? meta.roi ?? meta.rateOfInterest ?? 0; // annual %
  // --- get tenure in months (prefer bureau, else product master) ---
  let tenure = l?.details?.repaymentTenure ?? meta.tenure ?? meta.repaymentTenure ?? 0;

  // Determine simple-interest product using helper
  const isSimple = isSimpleInterestProduct(l, meta);

  // If marked SIMPLE OR product meta explicitly flagged (meta.simpleInterest true) → simple interest monthly
  if (isSimple) {
    // monthly interest on original principal (interest-only)
    // ROI may be 0 if missing — then EMI becomes 0
    const monthly = (principal * (Number(roi) || 0)) / (12 * 100);
    return Math.round(monthly); // keep integer rupee
  }

  // --- For normal EMI loans, use standard EMI formula ---
  // If ROI missing, we cannot compute; fall back to legacy meta.emiPerLakh if present
  if (!roi || Number(roi) <= 0) {
    if (meta.emiPerLakh) {
      const lakhs = principal / 100000;
      return Math.round(meta.emiPerLakh * lakhs);
    }
    return 0;
  }

  // If tenure missing or <=0 then fall back to meta.tenure if present
  if (!tenure || Number(tenure) <= 0) {
    tenure = meta.tenure ?? meta.defaultTenure ?? 0;
    if (!tenure || Number(tenure) <= 0) {
      // No tenure — can't compute annuity EMI; fallback to emiPerLakh if available
      if (meta.emiPerLakh) {
        const lakhs = principal / 100000;
        return Math.round(meta.emiPerLakh * lakhs);
      }
      return 0;
    }
  }

  // Convert to numbers
  const P = Number(principal);
  const r = Number(roi) / 1200; // monthly rate (decimal)
  const n = Number(tenure);

  // EMI formula: P*r*(1+r)^n / ((1+r)^n - 1)
  // careful numeric evaluation
  const pow = Math.pow(1 + r, n);
  if (!isFinite(pow) || pow === 1) return 0;
  const emi = P * r * pow / (pow - 1);

  return Math.round(emi);
}


