function buildEmiScheduleData(l) {
  // Always use sanctioned principal
  const principal = getSanctionAmount(l);
  const roi = getLoanRoi(l);
  const r = roi / 1200;
  const n = getLoanFullTenureMonths(l);

  if (!principal || !roi || !n) return [];

  let balance = principal;
  const schedule = [];

  // Calculate EMI once
  const pow = Math.pow(1 + r, n);
  const emi = (principal * r * pow) / (pow - 1);

  for (let i = 1; i <= n && balance > 1; i++) {
    const interest = balance * r;
    let principalComp = emi - interest;
    if (principalComp > balance) principalComp = balance;

    const closing = balance - principalComp;

    schedule.push({
      inst: i,
      opening: balance,
      closing: closing,
      emi,
      interest,
      principal: principalComp,
    });

    balance = closing;
  }

  return schedule;
}

function getCurrentBalanceFromSchedule(l) {
  const opened = l.details?.dateOpened || l.dateOpened || l.openDate;
  const schedule = buildEmiScheduleData(l);
  if (!schedule.length) return 0;

  const paid = countPaidEmis(opened);

  const today = new Date().getDate();

  // BEFORE 5th → return current month's balance
  if (today < 5) {
    // Paid 0 EMIs → use opening of EMI #1
    if (paid <= 0) return schedule[0].opening;

    // If paid >= schedule length → loan closed
    if (paid >= schedule.length) return 0;

    // Normal: return closing balance after last paid EMI
    return schedule[paid - 1].closing;
  }

  // AFTER 5th → return next month's balance
  const nextIndex = paid; // index of next EMI

  if (paid <= 0) return schedule[0].closing;   // closing after EMI #1
  if (nextIndex >= schedule.length) return 0;  // loan fully paid

  return schedule[nextIndex].closing;
}

function getPartPeriodInterest(l) {
  const schedule = buildEmiScheduleData(l);
  if (!schedule.length) return 0;

  const opened = l.details?.dateOpened || l.dateOpened || l.openDate;
  const outstanding = getCurrentBalanceFromSchedule(l);

  // Find the row matching outstanding
  let index = schedule.findIndex(
    row => Math.round(row.closing) === Math.round(outstanding)
  );

  if (index < 0) return 0;

  // Remaining interest begins from *next* row
  const nextIndex = index + 1;
  if (nextIndex >= schedule.length) return 0;

  // Monthly interest of next EMI row
  const monthlyInterest = schedule[nextIndex].interest;

  // Per-day interest
  const perDay = monthlyInterest / 30;

  // Days passed from 1st of month (1st = 0 days)
  const today = new Date();
  const daysPassed = Math.max(0, today.getDate() - 1);

  return Math.round(perDay * daysPassed);
}


 
