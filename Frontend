// DOM references
const gstIndustryInput = document.getElementById("gstIndustry");
const gstMarginInput = document.getElementById("gstMargin");
const gstBusinessTypeSel = document.getElementById("gstBusinessType");

// All industry names (sorted for nicer list)
const INDUSTRY_KEYS = Object.keys(INDUSTRY_MARGINS).sort();

// Create suggestion box element and attach below the input
const industrySuggestionBox = document.createElement("div");
industrySuggestionBox.className = "kf-industry-suggestions";
industrySuggestionBox.style.display = "none";

// Make parent relative so dropdown positions correctly
if (gstIndustryInput && gstIndustryInput.parentNode) {
  const parent = gstIndustryInput.parentNode;
  if (!parent.style.position) {
    parent.style.position = "relative";
  }
  parent.appendChild(industrySuggestionBox);
}

// Helper: get margin for a given industry & business type
function getMarginForIndustry(industryKey, type) {
  if (!industryKey || !type) return null;
  const row = INDUSTRY_MARGINS[industryKey];
  if (!row) return null;
  const val = row[type];
  return (val === null || val === undefined || isNaN(val)) ? null : val;
}

// Helper: closest / best industry match
function findClosestIndustry(userText) {
  if (!userText) return null;
  userText = userText.toLowerCase();

  // 1) Exact match
  let exact = INDUSTRY_KEYS.find(k => k.toLowerCase() === userText);
  if (exact) return exact;

  // 2) Contains
  let partial = INDUSTRY_KEYS.find(k => k.toLowerCase().includes(userText));
  if (partial) return partial;

  // 3) Simple fuzzy: count word overlaps
  let bestMatch = null;
  let bestScore = 0;
  INDUSTRY_KEYS.forEach(key => {
    const words = key.toLowerCase().split(/\s+/);
    let score = 0;
    words.forEach(w => {
      if (w && userText.includes(w)) score++;
    });
    if (score > bestScore) {
      bestScore = score;
      bestMatch = key;
    }
  });

  return bestMatch;
}


