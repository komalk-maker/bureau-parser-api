  function buildPaymentHistoryTable(dpdStr) {
    const months = [
      "Jan",
      "Feb",
      "Mar",
      "Apr",
      "May",
      "Jun",
      "Jul",
      "Aug",
      "Sep",
      "Oct",
      "Nov",
      "Dec"
    ];

    if (!dpdStr || !/\d/.test(String(dpdStr))) {
      const currentYear = new Date().getFullYear();
      const years = [currentYear, currentYear - 1, currentYear - 2, currentYear - 3];
      let header = `<tr><th>DPD</th>`;
      months.forEach(mn => (header += `<th>${mn}</th>`));
      header += `</tr>`;
      let body = "";
      years.forEach(year => {
        body += `<tr><td>${year}</td>`;
        for (let i = 0; i < 12; i++) {
          body += `<td class="kf-payhist-ok">0</td>`;
        }
        body += `</tr>`;
      });
      return `
        <div class="kf-payhist-label">Payment History (DPD)</div>
        <div style="overflow-x:auto;">
          <table class="kf-payhist-table">
            <thead>${header}</thead>
            <tbody>${body}</tbody>
          </table>
        </div>
      `;
    }

    const text = String(dpdStr);
    const regex = /(\d{4})[-/](\d{1,2})\s*:\s*([0-9]+)/g;
    const entries = [];
    let m;
    while ((m = regex.exec(text)) !== null) {
      const year = parseInt(m[1], 10);
      const monthIndex = parseInt(m[2], 10) - 1;
      const rawValue = parseInt(m[3], 10);
      if (
        !isNaN(year) &&
        monthIndex >= 0 &&
        monthIndex < 12 &&
        !isNaN(rawValue)
      ) {
        let displayValue = rawValue;
        if (rawValue >= 10 && rawValue % 10 === 0 && rawValue <= 90) {
          displayValue = rawValue / 10;
        }
        entries.push({ year, monthIndex, value: displayValue });
      }
    }

    const yearMap = {};
    entries.forEach(({ year, monthIndex, value }) => {
      if (!yearMap[year]) yearMap[year] = {};
      yearMap[year][monthIndex] = value;
    });

    let years;
    if (entries.length) {
      const maxYear = Math.max(...entries.map(e => e.year));
      years = [maxYear, maxYear - 1, maxYear - 2, maxYear - 3];
    } else {
      const currentYear = new Date().getFullYear();
      years = [currentYear, currentYear - 1, currentYear - 2, currentYear - 3];
    }

    let header = `<tr><th>DPD</th>`;
    months.forEach(mn => (header += `<th>${mn}</th>`));
    header += `</tr>`;
    let body = "";
    years.forEach(year => {
      body += `<tr><td>${year}</td>`;
      for (let i = 0; i < 12; i++) {
        const stored = yearMap[year] ? yearMap[year][i] : undefined;
        const v = typeof stored === "number" ? stored : 0;
        let cls;
        if (v === 0) cls = "kf-payhist-ok";
        else if (v > 0 && v <= 30) cls = "kf-payhist-minor";
        else cls = "kf-payhist-major";
        body += `<td class="${cls}">${v}</td>`;
      }
      body += `</tr>`;
    });

    return `
      <div class="kf-payhist-label">Payment History (DPD)</div>
      <div style="overflow-x:auto;">
        <table class="kf-payhist-table">
          <thead>${header}</thead>
          <tbody>${body}</tbody>
        </table>
      </div>
    `;
  }

