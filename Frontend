function closeModal() {
  if (!modal || !currentCard || !originalParent) return;

  // Hide modal
  modal.classList.remove("open");
  document.body.classList.remove("kf-modal-open");

  // Clear modal content
  modalBody.innerHTML = "";

  // Restore card to original position
  if (originalNextSibling && originalNextSibling.parentNode === originalParent) {
    originalParent.insertBefore(currentCard, originalNextSibling);
  } else {
    originalParent.appendChild(currentCard);
  }

  // Reset state
  currentCard.classList.remove("open");
  currentCard = null;
  originalParent = null;
  originalNextSibling = null;
}
  
// OUTER: all insight cards open in popup only (no inline accordion)
  document.querySelectorAll(".kf-insight-card-header").forEach(header => {
    header.addEventListener("click", () => {
      const card = header.closest(".kf-insight-card");
      if (!card || !modal || !modalBody) return;

      originalParent = card.parentNode;
      originalNextSibling = card.nextSibling;
      currentCard = card;

      // Ensure body is visible *inside* popup
      card.classList.add("open");

      // Move card into modal
      modalBody.innerHTML = "";
      modalBody.appendChild(card);

      // Show modal
      modal.classList.add("open");
      document.body.classList.add("kf-modal-open");
    });
  });

  if (modalClose) {
    modalClose.addEventListener("click", closeModal);
  }

  if (modal) {
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });
  }

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && modal.classList.contains("open")) {
      closeModal();
    }
  });

  // INNER: two boxes inside "Don’t have enough profits." (Avg Bank + GST)
  document.querySelectorAll(".kf-inner-header").forEach(header => {
    header.addEventListener("click", (e) => {
      e.stopPropagation(); // don't trigger popup
      const item = header.closest(".kf-inner-item");
      if (!item) return;
      const isOpen = item.classList.contains("open");
      item.classList.toggle("open", !isOpen);
    });
  });
}

