  // ---------- Helper: Max DPD from payment history ----------
  function getMaxDpdForLoan(l) {
    const d = l.details || {};
    const raw = d.dpdHistory;
    if (!raw) return 0;

    const text = String(raw);
    const regex = /(\d{4})[-/](\d{1,2})\s*:\s*([0-9]+)/g;
    let m;
    let max = 0;

    while ((m = regex.exec(text)) !== null) {
      const v = parseInt(m[3], 10);
      if (!isNaN(v) && v > max) max = v;
    }

    // Fallback: if pattern not matching, just take any numbers
    if (max === 0) {
      const nums = text.match(/\d+/g);
      if (nums) {
        nums.forEach(n => {
          const v = parseInt(n, 10);
          if (!isNaN(v) && v > max) max = v;
        });
      }
    }

    return max;
  }

function sanitizeDPD(dpds) {
  if (!dpds) return 0;

  const s = String(dpds).trim();

  // split into chunks of 2 digits: "2400000000" → ["24","00","00","00","00"]
  let chunks = s.match(/.{1,2}/g) || [];

  // convert to numbers
  let nums = chunks.map(x => parseInt(x, 10)).filter(n => Number.isFinite(n));

  if (!nums.length) return 0;

  // meaningful DPD cannot exceed 300 days logically
  nums = nums.filter(n => n <= 300);

  if (!nums.length) return 0;

  return Math.max(...nums);
}
function allocateFundsLoanWise(loans, monthlyFunds) {

  // Clone loan list
  let list = loans.map(l => ({
    lender: l.details?.lender || getBankName(l.line || ""),
    type: l.details?.accountType || l.type || "Loan",
    overdue: l.details?.amountOverdue || 0
  }));

  // Sort smallest overdue first
  list.sort((a, b) => a.overdue - b.overdue);

  let month = 1;
  let allocation = [];
  let hasRemaining = true;

  while (hasRemaining && month <= 18) { // max 18 months plan
    let available = monthlyFunds;
    hasRemaining = false;

    list.forEach(item => {
      if (item.overdue > 0 && available > 0) {

        hasRemaining = true;

        const pay = Math.min(item.overdue, available);

        allocation.push({
          month,
          lender: item.lender,
          type: item.type,
          pay,
          before: item.overdue,
          after: item.overdue - pay
        });

        item.overdue -= pay;
        available -= pay;
      }
    });

    month++;
  }

  return allocation;
}

