      }
    });
  }

  function findProductById(id) {
    return PRODUCT_TABLE.find(p => p.id === id) || null;
  }

  // Helper to compute EMI from amount/tenure/product
  function calculateNewLoanEmi(amount, tenureMonths, productId) {
    const meta = findProductById(productId);
    if (!meta || !meta.roi) return null;
    const r = meta.roi / 1200;
    const n = tenureMonths;
    if (!amount || amount <= 0 || !n || n <= 0) return null;
    if (r > 0) {
      const pow = Math.pow(1 + r, n);
      return (amount * r * pow) / (pow - 1);
    }
    return amount / n;
  }

