  function calculateForeclosureBenefit(l) {
  const outstanding = getCurrentBalanceFromSchedule(l);

  if (!outstanding || outstanding <= 0) {
    return {
      interestSaved: 0,
      foreclosureCharge: 0,
      foreclosureAmount: 0,
      netSaving: 0,
      principalOutstanding: 0
    };
  }

  // 1. full future interest
  let interestRemaining = estimateInterestRemaining(l);

  // 2. subtract part-period interest
  const partInterest = getPartPeriodInterest(l);
  interestRemaining = Math.max(0, interestRemaining - partInterest);

  const foreclosureCharge = outstanding * 0.04;
  const foreclosureAmount = outstanding + foreclosureCharge;
  const netSaving = Math.max(0, interestRemaining - foreclosureCharge);

  return {
    interestSaved: Math.round(interestRemaining),
    foreclosureCharge: Math.round(foreclosureCharge),
    foreclosureAmount: Math.round(foreclosureAmount),
    netSaving: Math.round(netSaving),
    principalOutstanding: Math.round(outstanding),
    partInterest: Math.round(partInterest)
  };
}



// ---------- EMI Schedule helpers (use getLoanFullTenureMonths; preserve interest-only) ----------
function buildEmiScheduleForLoan(l) {
  const meta = getProductMeta(l);
  const t = (l.type || "").toLowerCase();
  const at = (l.details?.accountType || "").toLowerCase();
  const line = (l.line || "").toLowerCase();
  const text = " " + t + " " + at + " " + line + " ";
  const label = (meta?.label || "").toLowerCase();

  // ------------------ SANCTION / PRINCIPAL ------------------
  let principal = getSanctionAmount(l);
  if (!principal || principal <= 0) principal = getCurrentBalance(l);
  if (!principal || principal <= 0) {
    return {
      html: "<div style='font-size:12px;color:#6b7280;'>Sanction amount not available for this loan.</div>"
    };
  }

  // ------------------ ROI: ALWAYS USE getLoanRoi(l) ------------------
  const roi = getLoanRoi(l);
  if (!roi || isNaN(roi) || roi <= 0) {
    return {
      html: "<div style='font-size:12px;color:#6b7280;'>ROI not available to build EMI schedule.</div>"
    };
  }
  const r = roi / 1200;

  // ------------------ INTEREST-ONLY DETECTION ------------------
  const isInterestOnly =
    text.includes("gold loan") ||
    label.includes("gold loan") ||
    text.includes("mudra") ||
    label.includes("mudra") ||
    text.includes("od limit") ||
    text.includes("overdraft") ||
    text.includes("cash credit") ||
    text.includes("cc limit") ||
    text.includes("secured od") ||
    text.includes("loan against share") ||
    text.includes("loan against shares") ||
    text.includes("loan against mf") ||
    text.includes("loan against mutual");

  if (isInterestOnly) {
    const monthlyInterest = principal * r;

    let rows = "";
    for (let i = 1; i <= 12; i++) {
      rows += `
        <tr>
          <td>${i}</td>
          <td>₹${formatINR(Math.round(monthlyInterest))}</td>
        </tr>
      `;
    }

    const summary = `
      <div style="font-size:11px;color:#374151;margin-bottom:6px;">
        <b>Interest-only facility</b> (example 12-month schedule)<br>
        Product: <b>${meta?.label || "Loan"}</b><br>
        Principal: <b>₹${formatINR(principal)}</b><br>
        ROI: <b>${roi}% p.a.</b><br>
        Monthly Interest: <b>₹${formatINR(Math.round(monthlyInterest))}</b>
      </div>
    `;

    return {
      html: `
        ${summary}
        <div style="overflow-x:auto;">
          <table class="kf-payhist-table">
            <thead>
              <tr><th>Inst.</th><th>Monthly Interest</th></tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
      `
    };
  }

  // ------------------ TENURE → ALWAYS USE getLoanFullTenureMonths(l) ------------------
  const fullTenure = getLoanFullTenureMonths(l);
  if (!fullTenure || fullTenure <= 0) {
    return {
      html: "<div style='font-size:12px;color:#6b7280;'>Full tenure not available for EMI schedule.</div>"
    };
  }

  const n = fullTenure;

  // ------------------ EMI FORMULA ------------------
  let emi = 0;
  if (r > 0) {
    const pow = Math.pow(1 + r, n);
    emi = (principal * r * pow) / (pow - 1);
  } else {
    emi = principal / n;
  }

  // ------------------ BUILD AMORTIZATION ------------------
  let rows = "";
  let balance = principal;
  let totalInterest = 0;
  let totalPrincipal = 0;

  for (let i = 1; i <= n && balance > 1; i++) {
    const interest = balance * r;
    let principalComp = emi - interest;
    if (principalComp > balance) principalComp = balance;

    const closing = balance - principalComp;

    rows += `
      <tr>
        <td>${i}</td>
        <td>₹${formatINR(Math.round(balance))}</td>
        <td>₹${formatINR(Math.round(emi))}</td>
        <td>₹${formatINR(Math.round(interest))}</td>
        <td>₹${formatINR(Math.round(principalComp))}</td>
        <td>₹${formatINR(Math.round(closing))}</td>
      </tr>
    `;

    balance = closing;
    totalInterest += interest;
    totalPrincipal += principalComp;
  }

  const summary = `
    <div style="font-size:11px;color:#374151;margin-bottom:6px;">
      EMI schedule for <b>${fullTenure} months</b> (full tenure)<br>
      Product: <b>${meta?.label || "Loan"}</b><br>
      Principal: <b>₹${formatINR(principal)}</b><br>
      ROI: <b>${roi}% p.a.</b><br>
      Estimated EMI: <b>₹${formatINR(Math.round(emi))}</b>/month
    </div>
  `;

  return {
    html: `
      ${summary}
      <div style="overflow-x:auto;">
        <table class="kf-payhist-table">
          <thead>
            <tr>
              <th>Inst.</th>
              <th>Opening</th>
              <th>EMI</th>
              <th>Interest</th>
              <th>Principal</th>
              <th>Closing</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
          <tfoot>
            <tr>
              <th colspan="3" style="text-align:right;">Totals:</th>
              <th>₹${formatINR(Math.round(totalInterest))}</th>
              <th>₹${formatINR(Math.round(totalPrincipal))}</th>
              <th></th>
            </tr>
          </tfoot>
        </table>
      </div>
    `
  };
}

