/* ===========================================
   ROI Overpricing Main Calculation
=========================================== */

window.calculateOverpriceForLoan = function (loan) {
  const benchKey = classifyLoanForRoiBenchmark(loan);
  if (!benchKey) return { error: "Loan type not supported." };

  const roiActual =
    Number(loan?.details?.rateOfInterest) ||
    Number(getLoanRoi(loan)) || 0;

  if (!roiActual) return { error: "Actual ROI unavailable." };

  const best = getProductMinRoi(benchKey);
  if (!best) return { error: `Min ROI missing for ${benchKey}` };

  const principal =
    Number(getCurrentBalance(loan)) ||
    Number(getSanctionAmount(loan)) || 0;

  const remainingMonths =
    getLoanRemainingTenureMonths(loan) || 12;

  const calcEmi = (P, r, n) => {
    const m = r / 12 / 100;
    return (P * m * Math.pow(1 + m, n)) /
           (Math.pow(1 + m, n) - 1);
  };

  const isSimple =
    loan?.details?.isSimpleInterest ||
    loan?.isSimpleInterest ||
    (typeof isSimpleInterestProduct === "function" &&
      isSimpleInterestProduct(loan));

  let extraEmi = 0, newEmi = 0,
      totalOldInterest = 0,
      totalNewInterest = 0,
      savings = 0;

  if (isSimple) {
    const intActual = principal * roiActual / 100;
    const intBest = principal * best.roi / 100;

    totalOldInterest = intActual;
    totalNewInterest = intBest;

    savings = intActual - intBest;
    extraEmi = savings / 12;
    newEmi = (principal / 12) + (intBest / 12);

  } else {
    const emiActual = calcEmi(principal, roiActual, remainingMonths);
    const emiBest = calcEmi(principal, best.roi, remainingMonths);

    newEmi = emiBest;
    extraEmi = emiActual - emiBest;

    totalOldInterest = emiActual * remainingMonths - principal;
    totalNewInterest = emiBest * remainingMonths - principal;

    savings = totalOldInterest - totalNewInterest;
  }

  return {
    benchKey,
    benchLabel: ROI_MASTER[benchKey]?.label || benchKey,
    roiActual,
    minRoi: best.roi,
    roiDiff: +(roiActual - best.roi).toFixed(2),
    isSimple,

    extraEmi,
    newEmi,
    totalOldInterest,
    totalNewInterest,
    savings
  };
};


