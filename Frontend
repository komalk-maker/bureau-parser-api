// ----------------- helper: simple-interest product detection -----------------
function isSimpleInterestProduct(l, meta = {}) {
  // Normalize label / account type for matching
  const acctType = (l?.details?.accountType || meta?.label || "").toString().toUpperCase();

  // Products that should be treated as SIMPLE interest (interest-only per month).
  // NOTE: CREDIT CARD / CC and SECURED CARD are intentionally NOT listed here,
  // because "Loan on Credit Card" should be treated as a normal EMI loan.
  const SIMPLE_PRODUCTS = [
    "GOLD",
"CREDIT CARD",
    "GOLD LOAN",
    "EDUCATION",
    "EDUCATION LOAN",
    "KCC",
    "KISAN CREDIT CARD",
    "MUDRA",
    "MUDRA LOAN",
    "SECURED OD",
    "OVERDRAFT",
    "OD",
    "LOAN AGAINST SHARES",
    "LOAN AGAINST MF",
    "LOAN AGAINST SHARES / MF"
  ];

  // detect a simple product by label presence
  let isSimple = SIMPLE_PRODUCTS.some(p => acctType.includes(p));

  // EXPLICIT OVERRIDES:
  // If this account is a "loan on credit card", treat it as a normal EMI loan (not simple interest).
  // Match variants like: "LOAN ON CREDIT CARD", "CC LOAN", "LOAN ON CARD", "CARD LOAN", etc.
  const isLoanOnCard = /LOAN\s*ON\s*(CREDIT\s*)?CARD|CC\s*LOAN|LOAN\s*ON\s*CARD|CARD\s*LOAN/i.test(acctType);
  if (isLoanOnCard) {
    isSimple = false;
  }

  // If product meta explicitly flags simple interest and it's NOT a loan-on-card, respect it
  if (meta.simpleInterest && !isLoanOnCard) {
    isSimple = true;
  }

  return !!isSimple;
}


