    };
    return map[issuerId] || issuerId || "";
  }

  function segmentLevel(segment) {
    if (!segment) return 1;
    const s = segment.toLowerCase();
    if (s.includes("super premium")) return 4;
    if (s.includes("premium")) return 3;
    if (s.includes("mid tier")) return 2;
    if (s.includes("mass")) return 2;
    return 1; // entry / fintech / others
  }

  function estimatedMinIncome(level) {
    if (level === 4) return 200000; // super premium
    if (level === 3) return 100000; // premium
    if (level === 2) return 60000;  // mid
    return 25000;                    // entry / fintech
  }

  function deriveTags(card) {
    const tags = [];
    const seg = (card.segment || "").toLowerCase();
    const name = (card.card_name || "").toLowerCase();
    const brand = (card.co_brand_partner || "").toLowerCase();

    if (seg.includes("cashback")) tags.push("cashback");
    if (seg.includes("online")) tags.push("online");
    if (seg.includes("rewards")) tags.push("rewards");
    if (seg.includes("travel") || seg.includes("miles") ||
        brand.includes("indigo") || brand.includes("makemytrip") ||
        brand.includes("easemytrip") || name.includes("marriott") ||
        name.includes("emirates") || name.includes("irctc")) {
      tags.push("travel");
    }
    if (seg.includes("fuel") || brand.includes("indianoil") || brand.includes("hpcl")) {
      tags.push("fuel");
    }
    if (seg.includes("dining") || brand.includes("zomato") || brand.includes("eazydiner")) {
      tags.push("dining");
    }
    if (seg.includes("lifestyle") || seg.includes("premium")) {
      tags.push("lifestyle");
    }
    if (card.joining_fee_rs === 0 && card.renewal_fee_rs === 0) {
      tags.push("lifetime_free");
    }
    return tags;
  }

  function platformMatchScore(card, platform) {
    if (!platform) return 0;
    const brand = (card.co_brand_partner || "").toLowerCase();
    const name = (card.card_name || "").toLowerCase();
    switch (platform) {
      case "amazon":
        return brand.includes("amazon") || name.includes("amazon") ? 25 : 0;
      case "flipkart":
        return brand.includes("flipkart") || name.includes("flipkart") ? 25 : 0;
      case "myntra":
        return brand.includes("myntra") || name.includes("myntra") ? 25 : 0;
      case "zomato":
        return brand.includes("zomato") || name.includes("zomato") ? 25 : 0;
      case "travel":
        return /indigo|makemytrip|easemytrip|irctc|marriott|emirates/.test(brand + " " + name) ? 25 : 0;
      case "fuel":
        return /indianoil|hpcl|bpcl/.test(brand + " " + name) ? 25 : 0;
      default:
        return 0;
    }
  }

