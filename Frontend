// 🔗 Your live backend URL
const GOVT_CHAT_API_URL =
  "https://bureau-parser-api.onrender.com/govt-schemes-chat";


// Chat memory
let govtChatHistory = [];
let GOVT_CHAT_STARTED = false;

// -----------------------------------------------------
// UI HELPERS
// -----------------------------------------------------

function govtAddMessage(text, sender = "bot") {
  const div = document.createElement("div");
  div.className = "kf-govt-chat-message " + sender;
  div.textContent = text;
  govtChatMessages.appendChild(div);
  govtChatMessages.scrollTop = govtChatMessages.scrollHeight;
}

function govtShowTyping() {
  const div = document.createElement("div");
  div.className = "kf-govt-chat-message bot kf-govt-typing";
  div.innerHTML = `
    <span class="kf-govt-typing-indicator">
      <span class="kf-govt-typing-dot"></span>
      <span class="kf-govt-typing-dot"></span>
      <span class="kf-govt-typing-dot"></span>
    </span>
  `;
  govtChatMessages.appendChild(div);
  govtChatMessages.scrollTop = govtChatMessages.scrollHeight;
  return div;
}

// -----------------------------------------------------
// QUICK FOLLOW-UP CHIPS
// -----------------------------------------------------

function govtShowFollowUps() {
  const chips = [
    "CGTMSE eligibility",
    "CGTMSE documents required",
    "PMAY-U ISS subsidy",
    "Any scheme for MSME?",
    "Which scheme suits me?"
  ];

  govtChatChips.innerHTML = chips
    .map(
      t => `<button class="kf-govt-chip"
                   onclick="govtSendChip('${t.replace(/'/g, "\\'")}')">
              ${t}
            </button>`
    )
    .join("");
}

function govtSendChip(text) {
  govtAddMessage(text, "user");
  govtChatHistory.push({ role: "user", content: text });
  govtCallApi();
}

// -----------------------------------------------------
// API CALL
// -----------------------------------------------------

async function govtCallApi() {
  const typingNode = govtShowTyping();
  govtChatSend.disabled = true;

  try {
    const res = await fetch(GOVT_CHAT_API_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        messages: govtChatHistory
      })
    });

    const data = await res.json();
    typingNode.remove();
    govtChatSend.disabled = false;

    const reply =
  (data && data.answer && data.answer.trim()) ||
  "Scheme document mein yeh clearly mention nahi hai.";

govtChatHistory.push({ role: "assistant", content: reply });
govtAddMessage(reply, "bot");

// Follow-up suggestions
if (data.followUps) {
  data.followUps
    .split("\n")
    .filter(Boolean)
    .forEach(q => govtAddMessage("👉 " + q, "bot"));
}


  } catch (err) {
    console.error(err);
    typingNode.remove();
    govtChatSend.disabled = false;
    govtAddMessage(
      "There was an error talking to the Govt Scheme assistant.",
      "bot"
    );
  }
}

// -----------------------------------------------------
// USER INPUT HANDLER
// -----------------------------------------------------

function govtHandleUserSend() {
  const text = (govtChatInput.value || "").trim();
  if (!text) return;

  govtChatInput.value = "";
  govtChatChips.innerHTML = "";

  govtAddMessage(text, "user");
  govtChatHistory.push({ role: "user", content: text });

  govtCallApi();
}

// -----------------------------------------------------
// CHAT START
// -----------------------------------------------------

function govtStartConversation() {
  if (GOVT_CHAT_STARTED) return;
  GOVT_CHAT_STARTED = true;

  const intro =
    "Namaste 👋 I’m your Govt Scheme assistant for India.\n\n" +
    "I answer ONLY from official scheme documents.\n\n" +
    "You can ask:\n" +
    "• Any scheme for MSME / business / housing\n" +
    "• Eligibility & subsidy details\n" +
    "• Documents required\n" +
    "• Claim / settlement process";

  govtChatHistory = [{ role: "assistant", content: intro }];
  govtAddMessage(intro, "bot");
}

// -----------------------------------------------------
// INIT
// -----------------------------------------------------

function initGovtSchemeChatUI() {
  if (!govtSchemeCard || !govtChatMessages ||
      !govtChatInput || !govtChatSend) return;

  govtSchemeCard.style.display = "block";

  govtChatSend.addEventListener("click", govtHandleUserSend);

  govtChatInput.addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      govtHandleUserSend();
    }
  });

  // Auto-start chat
  setTimeout(govtStartConversation, 300);
}


