/* CHART DRAWER */
function drawCashflowChart(data) {
  const ctx = document.getElementById("cashflowChart");

  const labels = data.map(x => x.month);
  const credits = data.map(x => x.credits);
  const debits = data.map(x => x.debits);

  new Chart(ctx, {
    type: "line",
    data: {
      labels,
      datasets: [
        {
          label: "Credits",
          data: credits
        },
        {
          label: "Debits",
          data: debits
        }
      ]
    },
    options: {
      responsive: true,
      tension: 0.3
    }
  });
}

