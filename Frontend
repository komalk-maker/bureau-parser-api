function computeApproxFundsAvailable() {
  const card = document.getElementById("fundsAvailableCard");
  const valueBox = document.getElementById("fundsAvailableValue");
  const listBox = document.getElementById("fundsAvailableList");

  if (!card || !valueBox || !listBox) return;

  listBox.innerHTML = "";

  if (!activeLoans || !activeLoans.length) {
    card.style.display = "none";
    return;
  }

  let totalAvailable = 0;
  let items = [];

  // PREPROCESS: Only highest-limit card per bank
  const highestCardPerBank = {};

  activeLoans.forEach(loan => {
    const meta = getProductMeta?.(loan) || {};
    const isSimple = isSimpleInterestProduct(loan, meta);
    if (!isSimple) return;

    const type = (loan.details?.accountType || loan.type || "").toUpperCase();
    if (!type.includes("CREDIT CARD")) return;

    const bank = getLoanDisplayName(loan) || "OTHER";
    const sanctioned = getSanctionAmount(loan) || 0;

    if (!highestCardPerBank[bank] || sanctioned > highestCardPerBank[bank].sanctioned) {
      highestCardPerBank[bank] = { loan, sanctioned };
    }
  });

  // MAIN LOOP
  activeLoans.forEach(loan => {
    let meta = {};
    try {
      const m = getProductMeta?.(loan);
      if (m && typeof m === "object") meta = m;
    } catch (e) { meta = {}; }

    const isSimple = isSimpleInterestProduct(loan, meta);
    if (!isSimple) return;

    const type = (loan.details?.accountType || loan.type || "").toUpperCase();

    // Skip duplicate cards of same bank
    if (type.includes("CREDIT CARD")) {
      const bank = getLoanDisplayName(loan) || "OTHER";
      if (highestCardPerBank[bank]?.loan !== loan) return;
    }

    const sanctioned = getSanctionAmount(loan) || 0;
    let currentOS = getCurrentBalance(loan);
    if (!Number.isFinite(currentOS)) currentOS = 0;

    let available = sanctioned - currentOS;
    if (!Number.isFinite(available) || available <= 0) return;

    totalAvailable += available;

    items.push({
      lender: getLoanDisplayName(loan),
      type: getLoanType(loan),
      available
    });
  });

  if (totalAvailable <= 0 || !items.length) {
    card.style.display = "none";
    return;
  }

  // SHOW CARD
  valueBox.textContent = "₹" + format(totalAvailable);
  card.style.display = "block";

  // RENDER ITEMS
  items.forEach(item => {
    const div = document.createElement("div");
    div.style.padding = "10px 0";
    div.style.borderBottom = "1px solid #e5e7eb";
    div.innerHTML = `
      <div style="font-weight:600;">${item.lender}</div>
      <div style="color:#6b7280;font-size:12px;">${item.type}</div>
      <div style="font-size:14px;font-weight:600;">₹${format(item.available)}</div>
    `;
    listBox.appendChild(div);
  });

  // ⭐ VERY IMPORTANT: EXPOSE VALUE GLOBALLY
  window.totalApproxFunds = totalAvailable;
}



