function computeFrontendTotalOutstanding(loans) {
  if (!Array.isArray(loans)) return 0;

  return loans.reduce((sum, l) => {
    if (!isActiveLoan(l)) return sum;

    const bal =
      Number(l?.details?.currentBalance) ||
      Number(l?.details?.outstandingBalance) ||
      Number(getCurrentBalance?.(l)) ||
      0;

    return sum + (bal > 0 ? bal : 0);
  }, 0);
}  
